# API Keys - at least one required for the agent to work
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# Default model to use (friendly name from model registry: gpt5, claude, groq)
DEFAULT_MODEL=gpt5

# Execution mode: "approval" (confirm each command) or "yolo" (auto-execute)
DEFAULT_MODE=approval

# Timeout in seconds for shell commands (0 = no timeout)
COMMAND_TIMEOUT=120

# Override the OpenRouter model string (model names can change without notice)
# OPENROUTER_MODEL=x-ai/grok-code-fast-1
